generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum HostelType {
  BOYS
  GIRLS
  MIXED
}

enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
  DORMITORY
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
}

enum AllocationStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum FeeFrequency {
  MONTHLY
  SEMESTER
  ONE_TIME
}

enum FeeCategory {
  HOSTEL_FEE
  SECURITY_DEPOSIT
  MAINTENANCE
  FINE
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  NET_BANKING
  BANK_TRANSFER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  RETURNED
}

enum VisitorRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id             String          @id @default(uuid())
  fullName       String
  email          String          @unique
  phone          String?         @unique
  passwordHash   String
  status         UserStatus      @default(ACTIVE)
  studentProfile StudentProfile?
  staffProfile   StaffProfile?
  roles          UserRole[]
  noticesCreated Notice[]        @relation("NoticeCreatedBy")
  auditLogs      AuditLog[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Role {
  id        String     @id @default(uuid())
  code      String     @unique
  name      String
  users     UserRole[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([roleId])
}

model Campus {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  address   String?
  hostels   Hostel[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Hostel {
  id             String              @id @default(uuid())
  campusId       String
  name           String
  code           String              @unique
  type           HostelType
  capacity       Int
  address        String?
  campus         Campus              @relation(fields: [campusId], references: [id], onDelete: Cascade)
  blocks         Block[]
  staff          StaffProfile[]
  feeStructures  FeeStructure[]
  applications   HostelApplication[]
  notices        Notice[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([campusId])
}

model Block {
  id        String   @id @default(uuid())
  hostelId  String
  name      String
  code      String
  hostel    Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  floors    Floor[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hostelId, code])
  @@index([hostelId])
}

model Floor {
  id        String   @id @default(uuid())
  blockId   String
  floorNo   Int
  block     Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  rooms     Room[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([blockId, floorNo])
  @@index([blockId])
}

model Room {
  id               String      @id @default(uuid())
  floorId          String
  roomNumber       String
  roomType         RoomType
  capacity         Int
  currentOccupancy Int         @default(0)
  floor            Floor       @relation(fields: [floorId], references: [id], onDelete: Cascade)
  beds             Bed[]
  roomAssets       RoomAsset[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([floorId, roomNumber])
  @@index([floorId])
}

model Bed {
  id          String       @id @default(uuid())
  roomId       String
  bedNumber    String
  status       BedStatus    @default(AVAILABLE)
  room         Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  allocations  Allocation[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([roomId, bedNumber])
  @@index([roomId, status])
}

model StudentProfile {
  id                 String              @id @default(uuid())
  userId             String              @unique
  rollNumber         String              @unique
  registrationNumber String?             @unique
  profilePhotoUrl    String?
  liveCapturePhotoUrl String?
  faceVerified       Boolean             @default(false)
  faceMatchScore     Float?
  faceVerifiedAt     DateTime?
  gender             Gender
  dateOfBirth        DateTime?
  department         String
  course             String
  yearOfStudy        Int
  semester           Int?
  guardianName       String?
  guardianPhone      String?
  address            String?
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications       HostelApplication[]
  allocations        Allocation[]
  feeInvoices        FeeInvoice[]
  feePayments        FeePayment[]
  leaveRequests      LeaveRequest[]
  visitorRequests    VisitorPassRequest[]
  complaints         Complaint[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model StaffProfile {
  id                String               @id @default(uuid())
  userId            String               @unique
  employeeId        String               @unique
  gender            Gender?
  designation       String
  joiningDate       DateTime?
  assignedHostelId  String?
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedHostel    Hostel?              @relation(fields: [assignedHostelId], references: [id])
  complaintsAssigned Complaint[]         @relation("ComplaintAssignedTo")
  leaveApproved     LeaveRequest[]       @relation("LeaveApprovedBy")
  visitorApproved   VisitorPassRequest[] @relation("VisitorApprovedBy")
  entryLogs         VisitorEntryLog[]    @relation("GatekeeperEntryLogs")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([assignedHostelId])
}

model HostelApplication {
  id                String            @id @default(uuid())
  studentId         String
  preferredHostelId String?
  academicYear      String
  reason            String?
  status            ApplicationStatus @default(PENDING)
  reviewedById      String?
  reviewedAt        DateTime?
  student           StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  preferredHostel   Hostel?           @relation(fields: [preferredHostelId], references: [id])
  allocations       Allocation[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([studentId, status])
  @@index([preferredHostelId])
}

model Allocation {
  id            String           @id @default(uuid())
  studentId     String
  bedId         String
  applicationId String?
  startDate     DateTime
  endDate       DateTime?
  status        AllocationStatus @default(ACTIVE)
  student       StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  bed           Bed              @relation(fields: [bedId], references: [id])
  application    HostelApplication? @relation(fields: [applicationId], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([studentId, status])
  @@index([bedId, status])
}

model FeeStructure {
  id           String        @id @default(uuid())
  hostelId     String?
  roomType     RoomType?
  academicYear String
  frequency    FeeFrequency
  category     FeeCategory
  amount       Decimal       @db.Decimal(10, 2)
  isActive     Boolean       @default(true)
  hostel       Hostel?       @relation(fields: [hostelId], references: [id])
  invoices     FeeInvoice[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([hostelId, academicYear, frequency])
}

model FeeInvoice {
  id              String         @id @default(uuid())
  studentId       String
  feeStructureId  String?
  invoiceNumber   String         @unique
  academicYear    String
  billingMonth    Int?
  billingSemester Int?
  amount          Decimal        @db.Decimal(10, 2)
  dueDate         DateTime
  status          PaymentStatus  @default(PENDING)
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure    FeeStructure?  @relation(fields: [feeStructureId], references: [id])
  payments        FeePayment[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([studentId, status])
  @@index([academicYear, billingMonth, billingSemester])
}

model FeePayment {
  id             String         @id @default(uuid())
  invoiceId      String
  studentId      String
  amountPaid     Decimal        @db.Decimal(10, 2)
  paymentDate    DateTime       @default(now())
  method         PaymentMethod
  transactionRef String?
  status         PaymentStatus  @default(PAID)
  invoice        FeeInvoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([invoiceId])
  @@index([studentId, paymentDate])
}

model LeaveRequest {
  id           String         @id @default(uuid())
  studentId    String
  reason       String
  fromDate     DateTime
  toDate       DateTime
  status       LeaveStatus    @default(PENDING)
  approvedById String?
  approvedAt   DateTime?
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  approvedBy   StaffProfile?  @relation("LeaveApprovedBy", fields: [approvedById], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([studentId, status])
  @@index([approvedById])
}

model Visitor {
  id                String               @id @default(uuid())
  fullName          String
  phone             String?
  idProofType       String?
  idProofNumber     String?
  relationToStudent String?
  requests          VisitorPassRequest[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model VisitorPassRequest {
  id           String               @id @default(uuid())
  studentId    String
  visitorId    String
  visitDate    DateTime
  purpose      String?
  status       VisitorRequestStatus @default(PENDING)
  approvedById String?
  approvedAt   DateTime?
  student      StudentProfile       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  visitor      Visitor              @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  approvedBy   StaffProfile?        @relation("VisitorApprovedBy", fields: [approvedById], references: [id])
  entryLogs    VisitorEntryLog[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([studentId, status])
  @@index([visitorId])
}

model VisitorEntryLog {
  id           String             @id @default(uuid())
  requestId     String
  gatekeeperId  String?
  checkInTime   DateTime?
  checkOutTime  DateTime?
  remarks       String?
  request       VisitorPassRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  gatekeeper    StaffProfile?      @relation("GatekeeperEntryLogs", fields: [gatekeeperId], references: [id])
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([requestId])
  @@index([gatekeeperId])
}

model Complaint {
  id           String            @id @default(uuid())
  studentId    String
  title        String
  description  String
  category     String
  priority     ComplaintPriority @default(MEDIUM)
  status       ComplaintStatus   @default(OPEN)
  assignedToId String?
  student      StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignedTo   StaffProfile?     @relation("ComplaintAssignedTo", fields: [assignedToId], references: [id])
  updates      ComplaintUpdate[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([studentId, status])
  @@index([assignedToId, status])
}

model ComplaintUpdate {
  id          String           @id @default(uuid())
  complaintId String
  message     String
  status      ComplaintStatus?
  complaint   Complaint        @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@index([complaintId])
}

model Notice {
  id          String    @id @default(uuid())
  hostelId    String?
  title       String
  content     String
  createdById String
  hostel      Hostel?   @relation(fields: [hostelId], references: [id])
  createdBy   User      @relation("NoticeCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([hostelId])
  @@index([createdById])
}

model Asset {
  id         String      @id @default(uuid())
  name       String
  assetType  String
  quantity   Int         @default(1)
  roomAssets RoomAsset[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model RoomAsset {
  id        String   @id @default(uuid())
  roomId    String
  assetId   String
  quantity  Int      @default(1)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, assetId])
  @@index([assetId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
}
